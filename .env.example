# AI·HOT — environment template. Copy to .env.local and fill in.
# On Vercel: most values are auto-provisioned by the Supabase Marketplace
# integration + the initial deploy. Run `vercel env pull .env.local --yes`
# to sync locally.

# ─── Supabase Postgres (auto-wired by Vercel Marketplace integration) ───
# POSTGRES_URL              # pooled runtime connection (port 6543)
# POSTGRES_URL_NON_POOLING  # direct / session-mode connection for migrations
# SUPABASE_URL              # REST base URL
# SUPABASE_SERVICE_ROLE_KEY # full-access key (server-side only)
# SUPABASE_ANON_KEY         # browser-safe key
# SUPABASE_JWT_SECRET       # for Supabase Auth (M3)

# ─── Azure OpenAI — STANDARD resource (enrich + score + embeddings) ───
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://<your-resource>.cognitiveservices.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-5.4-standard
AZURE_OPENAI_MODEL=gpt-5.4
AZURE_OPENAI_API_VERSION=2024-12-01-preview
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-large

# ─── Azure OpenAI — PRO resource (reserved for M4 agent loop) ───
# Separate Azure resource with OpenAI-compat /v1/ endpoint. Only used when
# AIHOT_SCORE_PROVIDER or the M4 agent explicitly requests the "pro" provider.
AZURE_OPENAI_PRO_API_KEY=
AZURE_OPENAI_PRO_ENDPOINT=https://<your-resource>.openai.azure.com/openai/v1/
AZURE_OPENAI_PRO_DEPLOYMENT=gpt-5.4-pro-standard

# ─── Optional fallback providers (not called by M2 workers) ───
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-7

GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-pro-preview

# ─── Tavily (web search / article extract; deferred to M3+) ───
TAVILY_API_KEY=

# ─── Task routing (which provider handles which workload) ───
# allowed: anthropic | gemini | azure-openai | azure-openai-pro
AIHOT_ENRICH_PROVIDER=azure-openai
AIHOT_SCORE_PROVIDER=azure-openai
AIHOT_EMBED_PROVIDER=azure-openai
